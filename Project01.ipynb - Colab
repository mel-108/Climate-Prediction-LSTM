      <pre class="editor flex monaco monaco-colorized colab colab" contenteditable="true" data-lang="notebook-python"><span><span></span></span><br><span><span></span></span><br><span><span class="mtk8">#8.&nbsp;FUTURE&nbsp;PROJECTIONS</span></span><br><span><span class="mtk8">#MinMaxScalar&nbsp;is&nbsp;used&nbsp;for&nbsp;scaling&nbsp;data&nbsp;between&nbsp;0&nbsp;a</span><span class="mtk8">nd&nbsp;1</span></span><br><span><span class="mtk8">#sequential&nbsp;creates&nbsp;a&nbsp;deep&nbsp;learning&nbsp;model</span></span><br><span><span class="mtk8">#LSTM-&nbsp;Long&nbsp;Short&nbsp;Term&nbsp;Memory&nbsp;layer&nbsp;used&nbsp;for&nbsp;predi</span><span class="mtk8">cting&nbsp;climate&nbsp;change&nbsp;prediction</span></span><br><span><span class="mtk8">#Dense&nbsp;-&nbsp;fully&nbsp;connected&nbsp;output&nbsp;layer</span></span><br><span><span class="mtk8">#dropout-&nbsp;prevents&nbsp;over&nbsp;fitting</span></span><br><span><span></span></span><br><span><span class="mtk19">import</span><span class="mtk1">&nbsp;numpy&nbsp;</span><span class="mtk19">as</span><span class="mtk1">&nbsp;np</span></span><br><span><span class="mtk19">import</span><span class="mtk1">&nbsp;pandas&nbsp;</span><span class="mtk19">as</span><span class="mtk1">&nbsp;pd</span></span><br><span><span class="mtk19">from</span><span class="mtk1">&nbsp;sklearn.preprocessing&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;MinMaxScaler</span></span><br><span><span class="mtk19">from</span><span class="mtk1">&nbsp;tensorflow.keras.models&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;Sequential</span></span><br><span><span class="mtk19">from</span><span class="mtk1">&nbsp;tensorflow.keras.layers&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;LSTM,&nbsp;Dense,&nbsp;Dropout</span></span><br><span><span></span></span><br><span><span class="mtk8">#time_steps&nbsp;uses&nbsp;8&nbsp;yrs&nbsp;to&nbsp;predict&nbsp;future&nbsp;yrs</span></span><br><span><span class="mtk1">time_steps=</span><span class="mtk12">8</span></span><br><span><span></span></span><br><span><span class="mtk8">#MinMaxScalar&nbsp;creates&nbsp;a&nbsp;scalar&nbsp;object</span></span><br><span><span class="mtk1">scaler=MinMaxScaler()</span></span><br><span><span class="mtk8">#fit_transform()&nbsp;learns&nbsp;the&nbsp;min&nbsp;&amp;max&nbsp;of&nbsp;each&nbsp;colum</span><span class="mtk8">n</span></span><br><span><span class="mtk8">#scales&nbsp;data&nbsp;between&nbsp;0&nbsp;and&nbsp;1</span></span><br><span><span class="mtk1">data_scaled=scaler.fit_transform(df[target_cols])</span></span><br><span><span></span></span><br><span><span class="mtk8">#creating&nbsp;a&nbsp;sequence</span></span><br><span><span class="mtk8">#year&nbsp;1-8&nbsp;used&nbsp;to&nbsp;predict&nbsp;year&nbsp;9</span></span><br><span><span class="mtk8">#year&nbsp;2-9&nbsp;used&nbsp;to&nbsp;predict&nbsp;year&nbsp;10</span></span><br><span><span class="mtk6">def</span><span class="mtk1"> </span><span class="mtk15">create_sequences</span><span class="mtk1">(</span><span class="mtk16">df</span><span class="mtk1">,</span><span class="mtk16">time_steps</span><span class="mtk1">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;X,y=[],[]</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">for</span><span class="mtk1">&nbsp;i&nbsp;</span><span class="mtk6">in</span><span class="mtk1"> </span><span class="mtk15">range</span><span class="mtk1">(</span><span class="mtk15">len</span><span class="mtk1">(data)-time_steps):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;X.append(df[i:i+time_steps])</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;y.append(df[i+time_steps])</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">return</span><span class="mtk1">&nbsp;np.array(X),np.array(y)</span></span><br><span><span></span></span><br><span><span class="mtk8">#x&nbsp;is&nbsp;past&nbsp;8&nbsp;yrs</span></span><br><span><span class="mtk8">#y&nbsp;is&nbsp;next&nbsp;yrs&nbsp;values</span></span><br><span><span class="mtk1">X,y=create_sequences(data_scaled,time_steps)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;9.&nbsp;Dividing&nbsp;the&nbsp;dataset&nbsp;into&nbsp;training&nbsp;and&nbsp;testin</span><span class="mtk8">g&nbsp;sets</span></span><br><span><span class="mtk8">#&nbsp;train&nbsp;sets&nbsp;contains&nbsp;80%&nbsp;dataset</span></span><br><span><span class="mtk8">#&nbsp;test&nbsp;sets&nbsp;contains&nbsp;20%&nbsp;dataset</span></span><br><span><span></span></span><br><span><span class="mtk1">train_size=</span><span class="mtk14">int</span><span class="mtk1">(</span><span class="mtk15">len</span><span class="mtk1">(X)*</span><span class="mtk12">0.8</span><span class="mtk1">)</span></span><br><span><span class="mtk1">X_train,X_test=X[:train_size],X[train_size:]</span></span><br><span><span class="mtk1">y_train,y_test=y[:train_size],y[train_size:]</span></span><br><span><span></span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;10.&nbsp;Building&nbsp;a&nbsp;LSTM&nbsp;model</span></span><br><span><span></span></span><br><span><span class="mtk8">#creates&nbsp;a&nbsp;empty&nbsp;neural&nbsp;network</span></span><br><span><span class="mtk1">model=Sequential()</span></span><br><span><span class="mtk8">#First&nbsp;LSTM&nbsp;layer&nbsp;with&nbsp;64&nbsp;neurons</span></span><br><span><span class="mtk8">#return_sequence=true;&nbsp;because,&nbsp;another&nbsp;LSTM&nbsp;layer</span><span class="mtk8">&nbsp;comes&nbsp;after&nbsp;the&nbsp;first&nbsp;layer</span></span><br><span><span class="mtk1">model.add(LSTM(</span><span class="mtk12">64</span><span class="mtk1">,return_sequences=</span><span class="mtk6">True</span><span class="mtk1">,input_shape=(time_steps,</span><span class="mtk15">len</span><span class="mtk1">(target_cols))))</span></span><br><span><span class="mtk8">#Dropout:&nbsp;drops&nbsp;20%&nbsp;of&nbsp;neurons&nbsp;randomly.&nbsp;Prevents&nbsp;</span><span class="mtk8">over&nbsp;fitting</span></span><br><span><span class="mtk1">model.add(Dropout(</span><span class="mtk12">0.2</span><span class="mtk1">))</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Second&nbsp;lstm&nbsp;layer&nbsp;with&nbsp;32&nbsp;neurons</span></span><br><span><span class="mtk8">#no&nbsp;return&nbsp;sequence=true&nbsp;because,&nbsp;this&nbsp;is&nbsp;the&nbsp;last</span><span class="mtk8">&nbsp;lstm&nbsp;layer</span></span><br><span><span class="mtk1">model.add(LSTM(</span><span class="mtk12">32</span><span class="mtk1">))</span></span><br><span><span class="mtk8">#Dropout:&nbsp;drops&nbsp;20%&nbsp;of&nbsp;neurons&nbsp;randomly</span></span><br><span><span class="mtk1">model.add(Dropout(</span><span class="mtk12">0.2</span><span class="mtk1">))</span></span><br><span><span class="mtk8">#outputs&nbsp;one&nbsp;value&nbsp;for&nbsp;each&nbsp;variable&nbsp;for&nbsp;6&nbsp;variabl</span><span class="mtk8">es&nbsp;6&nbsp;outputs</span></span><br><span><span class="mtk1">model.add(Dense(</span><span class="mtk15">len</span><span class="mtk1">(target_cols)))</span></span><br><span><span></span></span><br><span><span class="mtk8">#compiling&nbsp;the&nbsp;model</span></span><br><span><span class="mtk8">#&nbsp;adam&nbsp;=&nbsp;smart&nbsp;optimize&nbsp;,&nbsp;loss=mse&nbsp;mean&nbsp;squared&nbsp;er</span><span class="mtk8">ror&nbsp;used&nbsp;for&nbsp;regression</span></span><br><span><span class="mtk1">model.</span><span class="mtk15">compile</span><span class="mtk1">(optimizer=</span><span class="mtk21">'adam'</span><span class="mtk1">,loss=</span><span class="mtk21">'mse'</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;training&nbsp;model</span></span><br><span><span class="mtk8">#&nbsp;epochs=300&nbsp;:&nbsp;model&nbsp;sees&nbsp;the&nbsp;dataset&nbsp;300&nbsp;times</span></span><br><span><span class="mtk8">#&nbsp;batch_size=4:&nbsp;updates&nbsp;the&nbsp;weight&nbsp;for&nbsp;every&nbsp;4&nbsp;sam</span><span class="mtk8">ples</span></span><br><span><span class="mtk8">#&nbsp;verbose=1&nbsp;:&nbsp;shows&nbsp;training&nbsp;progress</span></span><br><span><span class="mtk1">model.fit(X_train,y_train,epochs=</span><span class="mtk12">500</span><span class="mtk1">,batch_size=</span><span class="mtk12">4</span><span class="mtk1">,verbose=</span><span class="mtk12">1</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;project&nbsp;future:&nbsp;function&nbsp;to&nbsp;predict&nbsp;future&nbsp;yrs</span></span><br><span><span></span></span><br><span><span class="mtk6">def</span><span class="mtk1"> </span><span class="mtk15">project_future</span><span class="mtk1">(</span><span class="mtk16">model</span><span class="mtk1">,</span><span class="mtk16">data_scaled</span><span class="mtk1">,</span><span class="mtk16">n_years</span><span class="mtk1">,</span><span class="mtk16">time_steps</span><span class="mtk1">):</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;Future&nbsp;predictions:&nbsp;an&nbsp;empty&nbsp;list&nbsp;is&nbsp;used&nbsp;to&nbsp;sto</span><span class="mtk8">re&nbsp;predictions</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;future_predictions=[]</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;takes&nbsp;last&nbsp;8&nbsp;yrs&nbsp;as&nbsp;input</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;input_seq=data_scaled[-time_steps:].copy()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;repeat&nbsp;the&nbsp;prediction&nbsp;for&nbsp;number&nbsp;of&nbsp;future&nbsp;years</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">for</span><span class="mtk1">&nbsp;_&nbsp;</span><span class="mtk6">in</span><span class="mtk1"> </span><span class="mtk15">range</span><span class="mtk1">(n_years):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;input&nbsp;is&nbsp;reshaped&nbsp;to&nbsp;(1,sample,8&nbsp;years,features)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pred=model.predict(input_seq.reshape(</span><span class="mtk12">1</span><span class="mtk1">,time_steps,data_scaled.shape[</span><span class="mtk12">1</span><span class="mtk1">]),verbose=</span><span class="mtk12">0</span><span class="mtk1">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;future_predictions.append(pred[</span><span class="mtk12">0</span><span class="mtk1">])</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;Removes&nbsp;oldest&nbsp;year&nbsp;and&nbsp;adds&nbsp;predicted&nbsp;year&nbsp;so,&nbsp;</span><span class="mtk8">that&nbsp;prediction&nbsp;becomes&nbsp;input&nbsp;for&nbsp;next&nbsp;prediction</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;This&nbsp;is&nbsp;called&nbsp;recursive&nbsp;multi&nbsp;step&nbsp;forecasting</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;input_seq=np.vstack((input_seq[</span><span class="mtk12">1</span><span class="mtk1">:],pred))</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;returns&nbsp;the&nbsp;predicted&nbsp;values</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">return</span><span class="mtk1">&nbsp;np.array(future_predictions)</span></span><br><span><span></span></span><br><span><span class="mtk8">#predicts&nbsp;next&nbsp;20&nbsp;future&nbsp;years&nbsp;(scaled&nbsp;values)</span></span><br><span><span class="mtk1">n_years=</span><span class="mtk12">20</span></span><br><span><span class="mtk1">future_scaled=project_future(model,data_scaled,n_y</span><span class="mtk1">ears,time_steps)</span></span><br><span><span class="mtk8">#&nbsp;converting&nbsp;the&nbsp;scaled&nbsp;values(0-1)&nbsp;to&nbsp;real&nbsp;values</span><span class="mtk8">&nbsp;such&nbsp;as&nbsp;co2,&nbsp;sea&nbsp;level&nbsp;etc</span></span><br><span><span class="mtk1">future_pred=scaler.inverse_transform(future_scaled</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#generating&nbsp;future&nbsp;years</span></span><br><span><span class="mtk8">#&nbsp;the&nbsp;last&nbsp;year&nbsp;is&nbsp;2011</span></span><br><span><span class="mtk8">#&nbsp;future&nbsp;years&nbsp;starts&nbsp;from&nbsp;2012,2013,2014....</span></span><br><span><span class="mtk1">last_year=</span><span class="mtk14">int</span><span class="mtk1">(df[</span><span class="mtk21">'Year'</span><span class="mtk1">].iloc[</span><span class="mtk12">-1</span><span class="mtk1">])</span></span><br><span><span class="mtk1">future_years=np.arange(last_year+</span><span class="mtk12">1</span><span class="mtk1">,last_year+n_years+</span><span class="mtk12">1</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;creating&nbsp;a&nbsp;final&nbsp;dataframe</span></span><br><span><span class="mtk8">#&nbsp;dataframe:&nbsp;0,&nbsp;Year,&nbsp;co2,&nbsp;methane.....</span></span><br><span><span class="mtk1">future_df=pd.DataFrame(future_pred,columns=target_</span><span class="mtk1">cols)</span></span><br><span><span class="mtk1">future_df.insert(</span><span class="mtk12">0</span><span class="mtk1">,</span><span class="mtk21">'Year'</span><span class="mtk1">,future_years)</span></span><br><span><span></span></span><br><span><span class="mtk8">#printing&nbsp;rounded&nbsp;results</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(future_df.</span><span class="mtk15">round</span><span class="mtk1">(</span><span class="mtk12">2</span><span class="mtk1">))</span></span><br></pre><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
