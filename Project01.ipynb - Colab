ning&nbsp;d</span><span class="mtk8">ata&nbsp;100&nbsp;times</span></span><br><span><span class="mtk8">#&nbsp;barch_size=4&nbsp;the&nbsp;data&nbsp;is&nbsp;split&nbsp;into&nbsp;mini&nbsp;batches</span><span class="mtk8">&nbsp;of&nbsp;4&nbsp;samples</span></span><br><span><span class="mtk8">#&nbsp;validation_aplit=0.1&nbsp;10%&nbsp;of&nbsp;the&nbsp;training&nbsp;data&nbsp;is</span><span class="mtk8">&nbsp;held&nbsp;out&nbsp;as&nbsp;validation&nbsp;set</span></span><br><span><span class="mtk8">#&nbsp;verbose=0&nbsp;controls&nbsp;how&nbsp;much&nbsp;output&nbsp;is&nbsp;shown&nbsp;duri</span><span class="mtk8">ng&nbsp;training</span></span><br><span><span></span></span><br><span><span class="mtk1">model.fit(X_train,y_train,epochs=</span><span class="mtk12">200</span><span class="mtk1">,batch_size=</span><span class="mtk12">4</span><span class="mtk1">,validation_split=</span><span class="mtk12">0.1</span><span class="mtk1">,verbose=</span><span class="mtk12">1</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;y_pted_scaled&nbsp;gives&nbsp;scaled&nbsp;output&nbsp;because&nbsp;the&nbsp;mo</span><span class="mtk8">del&nbsp;was&nbsp;trained&nbsp;on&nbsp;scaled&nbsp;data</span></span><br><span><span class="mtk8">#&nbsp;y_pred&nbsp;converts&nbsp;the&nbsp;scaled&nbsp;predicted&nbsp;values&nbsp;back</span><span class="mtk8">&nbsp;to&nbsp;the&nbsp;original&nbsp;scale&nbsp;without&nbsp;this&nbsp;the&nbsp;predicted&nbsp;</span><span class="mtk8">values&nbsp;will&nbsp;be&nbsp;0-1</span></span><br><span><span class="mtk8">#&nbsp;y_true&nbsp;this&nbsp;converts&nbsp;an&nbsp;actual&nbsp;values&nbsp;from&nbsp;scale</span><span class="mtk8">d&nbsp;form&nbsp;back&nbsp;to&nbsp;the&nbsp;original&nbsp;real-world&nbsp;values</span></span><br><span><span></span></span><br><span><span class="mtk1">y_pred_scaled=model.predict(X_test)</span></span><br><span><span class="mtk1">y_pred=scaler.inverse_transform(y_pred_scaled)</span></span><br><span