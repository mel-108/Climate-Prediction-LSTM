      <pre class="editor flex monaco monaco-colorized colab colab" contenteditable="true" data-lang="notebook-python"><span><span></span></span><br><span><span></span></span><br><span><span class="mtk8">#11.&nbsp;SCENARIO&nbsp;ANALYSIS</span></span><br><span><span class="mtk8">#&nbsp;defining&nbsp;scenario&nbsp;projection&nbsp;function</span></span><br><span><span class="mtk8">#&nbsp;arguments:&nbsp;model:&nbsp;trained&nbsp;lstm&nbsp;model</span></span><br><span><span class="mtk8">#&nbsp;data_scaled:&nbsp;scaled&nbsp;dataset&nbsp;after&nbsp;minmaxscalar</span></span><br><span><span class="mtk8">#&nbsp;n_years&nbsp;:&nbsp;number&nbsp;of&nbsp;future&nbsp;years&nbsp;to&nbsp;predict</span></span><br><span><span class="mtk8">#&nbsp;time_steps:&nbsp;number&nbsp;of&nbsp;past&nbsp;years&nbsp;the&nbsp;model&nbsp;uses&nbsp;</span><span class="mtk8">for&nbsp;prediction</span></span><br><span><span class="mtk8">#&nbsp;scenario&nbsp;:&nbsp;defines&nbsp;the&nbsp;baseline,&nbsp;high&nbsp;and&nbsp;low&nbsp;em</span><span class="mtk8">issions</span></span><br><span><span></span></span><br><span><span class="mtk6">def</span><span class="mtk1"> </span><span class="mtk15">scenario_projection</span><span class="mtk1">(</span><span class="mtk16">model</span><span class="mtk1">,</span><span class="mtk16">data_scaled</span><span class="mtk1">,</span><span class="mtk16">n_years</span><span class="mtk1">,</span><span class="mtk16">time_steps</span><span class="mtk1">,</span><span class="mtk16">scenario</span><span class="mtk1">=</span><span class="mtk21">"baseline"</span><span class="mtk1">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;takes&nbsp;the&nbsp;last&nbsp;time_steps&nbsp;rows&nbsp;from&nbsp;the&nbsp;scaled&nbsp;d</span><span class="mtk8">ataset</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;this&nbsp;becomes&nbsp;the&nbsp;starting&nbsp;input&nbsp;for&nbsp;future&nbsp;predi</span><span class="mtk8">ction</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;.copy()&nbsp;:&nbsp;prevents&nbsp;modifying&nbsp;original&nbsp;data</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;input_seq=data_scaled[-time_steps:].copy()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;future_predictions&nbsp;:&nbsp;creating&nbsp;an&nbsp;empty&nbsp;list&nbsp;whic</span><span class="mtk8">h&nbsp;stores&nbsp;all&nbsp;predicted&nbsp;future&nbsp;values</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;future_predictions=[]</span></span><br><span><span></span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;dictionary&nbsp;that&nbsp;defines</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;1.&nbsp;Baseline:&nbsp;0&nbsp;changes</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;2.&nbsp;High&nbsp;:&nbsp;increases&nbsp;the&nbsp;prediction&nbsp;by&nbsp;1%</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;3.&nbsp;Low&nbsp;:&nbsp;decreases&nbsp;the&nbsp;prediction&nbsp;by&nbsp;1%</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;scenario_factor&nbsp;=&nbsp;{</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk21">"baseline"</span><span class="mtk1">:</span><span class="mtk12">0.0</span><span class="mtk1">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk21">"high"</span><span class="mtk1">:</span><span class="mtk12">0.01</span><span class="mtk1">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk21">"low"</span><span class="mtk1">:</span><span class="mtk12">-0.01</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;}</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;gets&nbsp;the&nbsp;factor&nbsp;based&nbsp;on&nbsp;the&nbsp;selected&nbsp;scenario.&nbsp;</span><span class="mtk8">If&nbsp;the&nbsp;scenario&nbsp;not&nbsp;found&nbsp;default&nbsp;is&nbsp;0.0</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;factor=scenario_factor.get(scenario,</span><span class="mtk12">0.0</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;each&nbsp;loop&nbsp;predicts&nbsp;one&nbsp;future&nbsp;year</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">for</span><span class="mtk1">&nbsp;_&nbsp;</span><span class="mtk6">in</span><span class="mtk1"> </span><span class="mtk15">range</span><span class="mtk1">(n_years):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;reshaping&nbsp;input&nbsp;to&nbsp;match&nbsp;lstm&nbsp;format:&nbsp;(samples,t</span><span class="mtk8">ime_steps,features)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;predicts&nbsp;next&nbsp;year's&nbsp;values</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pred=model.predict(input_seq.reshape(</span><span class="mtk12">1</span><span class="mtk1">,time_steps,data_scaled.shape[</span><span class="mtk12">1</span><span class="mtk1">]),verbose=</span><span class="mtk12">0</span><span class="mtk1">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;applying&nbsp;the&nbsp;scenario&nbsp;adjustments&nbsp;like&nbsp;high&nbsp;and&nbsp;</span><span class="mtk8">low&nbsp;emissions</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;adjusted_pred=pred+factor*pred</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;adds&nbsp;predicted&nbsp;values&nbsp;to&nbsp;the&nbsp;list</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;[0]&nbsp;removes&nbsp;extra&nbsp;dimension</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;future_predictions.append(adjusted_pred[</span><span class="mtk12">0</span><span class="mtk1">])</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;updating&nbsp;input&nbsp;sequence</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;removes&nbsp;the&nbsp;oldest&nbsp;year&nbsp;input_seq[1:]</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;adds&nbsp;new&nbsp;predicted&nbsp;year&nbsp;at&nbsp;bottom&nbsp;this&nbsp;creates&nbsp;a</span><span class="mtk8">&nbsp;rolling&nbsp;window</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;so,&nbsp;the&nbsp;prediction&nbsp;keeps&nbsp;moving&nbsp;forward&nbsp;year&nbsp;by&nbsp;</span><span class="mtk8">year</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;input_seq=np.vstack((input_seq[</span><span class="mtk12">1</span><span class="mtk1">:],adjusted_pred))</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;converts&nbsp;the&nbsp;list&nbsp;to&nbsp;numpy&nbsp;array.&nbsp;Returns&nbsp;the&nbsp;pr</span><span class="mtk8">edicted&nbsp;future&nbsp;values</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">return</span><span class="mtk1">&nbsp;np.array(future_predictions)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;20&nbsp;future&nbsp;years</span></span><br><span><span class="mtk1">n_years=</span><span class="mtk12">20</span></span><br><span><span class="mtk8">#&nbsp;runs&nbsp;predictions&nbsp;for:&nbsp;baseline,&nbsp;high&nbsp;emissions&nbsp;a</span><span class="mtk8">nd&nbsp;low&nbsp;emissions</span></span><br><span><span class="mtk1">baseline_scaled=scenario_projection(model,data_sca</span><span class="mtk1">led,n_years,&nbsp;time_steps,</span><span class="mtk21">"baseline"</span><span class="mtk1">)</span></span><br><span><span class="mtk1">high_scaled=scenario_projection(model,data_scaled,</span><span class="mtk1">n_years,time_steps,</span><span class="mtk21">"high"</span><span class="mtk1">)</span></span><br><span><span class="mtk1">low_scaled=scenario_projection(model,data_scaled,n</span><span class="mtk1">_years,time_steps,</span><span class="mtk21">"low"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;converting&nbsp;the&nbsp;scaled&nbsp;predictions&nbsp;back&nbsp;to&nbsp;real&nbsp;c</span><span class="mtk8">limate&nbsp;values</span></span><br><span><span class="mtk1">baseline=scaler.inverse_transform(baseline_scaled)</span></span><br><span><span class="mtk1">high=scaler.inverse_transform(high_scaled)</span></span><br><span><span class="mtk1">low=scaler.inverse_transform(low_scaled)</span></span><br><span><span></span></span><br><span><span class="mtk1">future_years=np.arange(df[</span><span class="mtk21">'Year'</span><span class="mtk1">].iloc[</span><span class="mtk12">-1</span><span class="mtk1">]+</span><span class="mtk12">1</span><span class="mtk1">,df[</span><span class="mtk21">'Year'</span><span class="mtk1">].iloc[</span><span class="mtk12">-1</span><span class="mtk1">]+n_years+</span><span class="mtk12">1</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;converting&nbsp;predictions&nbsp;into&nbsp;structured&nbsp;dataframe</span></span><br><span><span class="mtk1">baseline_df=pd.DataFrame(baseline,columns=target_c</span><span class="mtk1">ols)</span></span><br><span><span class="mtk1">high_df=pd.DataFrame(high,columns=target_cols)</span></span><br><span><span class="mtk1">low_df=pd.DataFrame(low,columns=target_cols)</span></span><br><span><span></span></span><br><span><span class="mtk1">baseline_df.insert(</span><span class="mtk12">0</span><span class="mtk1">,</span><span class="mtk21">"Year"</span><span class="mtk1">,future_years)</span></span><br><span><span class="mtk1">high_df.insert(</span><span class="mtk12">0</span><span class="mtk1">,</span><span class="mtk21">"Year"</span><span class="mtk1">,future_years)</span></span><br><span><span class="mtk1">low_df.insert(</span><span class="mtk12">0</span><span class="mtk1">,</span><span class="mtk21">"Year"</span><span class="mtk1">,future_years)</span></span><br></pre><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
